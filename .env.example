# ============================================================
# Viaje Bem — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Banco de Dados ---
DB_USUARIO=viajebem
DB_SENHA=viajebem_senha
DB_NOME=viajebem_db
DB_HOST=db
DB_PORTA=5432
DATABASE_URL=postgresql+asyncpg://${DB_USUARIO}:${DB_SENHA}@${DB_HOST}:${DB_PORTA}/${DB_NOME}

# --- Autenticação JWT ---
JWT_SECRETO=TROQUE_POR_UMA_CHAVE_ALEATORIA_SEGURA
JWT_ALGORITMO=HS256
JWT_EXPIRACAO_MINUTOS=60

# --- Seed do ADMIN inicial ---
ADMIN_EMAIL=admin@viajebem.com.br
ADMIN_SENHA=TroqueEssaSenha123!
ADMIN_NOME=Administrador

# --- SMTP (MailHog em desenvolvimento) ---
SMTP_HOST=mailhog
SMTP_PORTA=1025
SMTP_TLS=false
SMTP_USUARIO=
SMTP_SENHA=
EMAIL_REMETENTE=noreply@viajebem.com.br

# --- Negócio ---
CHAVE_PIX=admin@viajebem.com.br
DIAS_TRAVA_SEGURO=7
LIMIAR_ULTIMAS_VAGAS=5

# --- Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:8000
